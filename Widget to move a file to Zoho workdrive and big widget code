        function handleSectionAction(plotId, action) {
            if (!action) return;

            if (action === 'delete') {
                if (confirm('Are you sure you want to delete this section?')) {
                    delete plotDataMap[plotId];
                    const el = document.getElementById(plotId);
                    if (el) el.remove();
                    if (Object.keys(plotDataMap).length === 0) {
                        document.getElementById('no-sections-alert').style.display = 'block';
                    }
                }
            } else if (action === 'duplicate') {
                const source = plotDataMap[plotId];
                const newPlotId = 'plot-' + Date.now();
                const newTitle = source.title + ' (Copy)';

                // Clone data
                plotDataMap[newPlotId] = JSON.parse(JSON.stringify(source));
                plotDataMap[newPlotId].title = newTitle;

                // Re-generate IDs for records to avoid collisions
                plotDataMap[newPlotId].records = plotDataMap[newPlotId].records.map(rec => ({
                    ...rec,
                    id: 'item-' + Math.random().toString(36).substr(2, 9)
                }));

                // Insert DOM
                document.getElementById('sections-container').insertAdjacentHTML('beforeend', getSectionTemplate(newPlotId, newTitle));
                renderSectionProducts(newPlotId);
                initRecordSortable(newPlotId);
                document.getElementById('no-sections-alert').style.display = 'none';
            }

            const sel = document.querySelector(`#${plotId} .plot-header select`);
            if (sel) sel.value = '';
        }

        // ─── Add a new plot/section ────────────────────────────────────────────────
        function addSection() {
            const nameInput = document.getElementById('new-section-name');
            plotCount++;
            const label = nameInput.value.trim() || `Plot ${plotCount}`;
            const plotId = `plot-${plotCount}`;
