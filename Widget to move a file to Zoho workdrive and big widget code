        function closeModal() {
            document.getElementById('quoted-items-modal').classList.remove('active');
            currentPlotId = null;
        }

        function renderModalRows() {
            const tbody = document.getElementById('modal-tbody');
            tbody.innerHTML = '';

            const data = plotDataMap[currentPlotId];
            const allRecords = [];
            data.locations.forEach(loc => {
                loc.records.forEach(r => {
                    allRecords.push({ ...r, locationName: loc.name });
                });
            });

            // If there are no records, create one
            if (allRecords.length === 0) {
                tbody.insertAdjacentHTML('beforeend', buildRowHtml(0, {}));
            }
            else {
                allRecords.forEach((row, i) => {
                    tbody.insertAdjacentHTML('beforeend', buildRowHtml(i, row));
                });
            }

            document.getElementById('modal-adjustment').value =
                data.adjustment.toFixed(2);

            recalcTotals();
        }

        function buildRowHtml(index, row) {
            const r = row || {};
            const id = r.id || `item-${++itemCount}`;
            const qty = Number(r.Quantity ?? r.qty ?? r.Qty ?? 1);
            const price = r.listPrice != null ? r.listPrice.toFixed(2) : '0.00';
            const disc = r.discount != null ? r.discount.toFixed(2) : '0.00';
            const tax = r.tax != null ? r.tax.toFixed(2) : '0.00';
            const amount = r.amount != null ? r.amount.toFixed(2) : (qty * parseFloat(price)).toFixed(2);
            const total = r.total != null ? r.total.toFixed(2) : '0.00';
            const locationName = r.locationName || 'Default';
            return `
        <tr class="modal-row" data-id="${id}" data-location="${locationName}">
            <td style="text-align:center;color:#888;width:46px;">${index + 1}</td>
            <td><input type="text"   class="table-input row-product"  value="${r.productName || ''}" placeholder="Product name" oninput="syncRows()"></td>
            <td><input type="number" class="table-input row-qty"      value="${qty}"   min="0" step="1"    oninput="recalcRow(this.closest('tr')); syncRows()"></td>
            <td><input type="number" class="table-input row-price"    value="${price}" min="0" step="0.01" oninput="recalcRow(this.closest('tr')); syncRows()"></td>
            <td class="row-amount" style="color:#555;">${amount}</td>
            <td><input type="number" class="table-input row-discount" value="${disc}"  min="0" step="0.01" oninput="recalcRow(this.closest('tr')); syncRows()"></td>
            <td><input type="number" class="table-input row-tax"      value="${tax}"   min="0" step="0.01" oninput="recalcRow(this.closest('tr')); syncRows()"></td>
            <td class="row-total" style="color:#333;font-weight:500;">${total}</td>
            <td style="text-align:center;">
                <button type="button" style="background:none;border:none;color:#d9534f;cursor:pointer;" onclick="removeModalRow(this)">
                    <i class="fa-solid fa-trash"></i>
                </button>
            </td>
        </tr>`;
        }

        function addModalRow() {
            const tbody = document.getElementById('modal-tbody');
            tbody.insertAdjacentHTML('beforeend', buildRowHtml(tbody.children.length, null));
            const newTr = tbody.lastElementChild;
            recalcRow(newTr);
            syncRows();
        }

        function removeModalRow(btn) {
            btn.closest('tr').remove();
            document.querySelectorAll('#modal-tbody .modal-row').forEach((tr, i) => {
                tr.cells[0].textContent = i + 1;
            });
            syncRows();
            recalcTotals();
        }

        // Recalculate Amount and Total cells for a single <tr>
        function recalcRow(tr) {
            const qty = parseFloat(tr.querySelector('.row-qty').value) || 0;
            const price = parseFloat(tr.querySelector('.row-price').value) || 0;
            const discount = parseFloat(tr.querySelector('.row-discount').value) || 0;
            const tax = parseFloat(tr.querySelector('.row-tax').value) || 0;
            const amount = qty * price;
            const total = (amount - discount) + tax;
            tr.querySelector('.row-amount').textContent = amount.toFixed(2);
            tr.querySelector('.row-total').textContent = total.toFixed(2);
        }

        // Recalculate and update the summary box
        function recalcTotals() {
            let subTotal = 0, disc = 0, tax = 0;
            document.querySelectorAll('#modal-tbody .modal-row').forEach(tr => {
                subTotal += parseFloat(tr.querySelector('.row-total').textContent) || 0; // Assuming total includes tax/disc
                // Note: The previous logic for subTotal/tax was a bit inconsistent with ZOHO records
                // Let's just sum up directly for simplicity in this view
            });
            // Re-calculating properly from row values for the summary:
            subTotal = 0; disc = 0; tax = 0;
            document.querySelectorAll('#modal-tbody .modal-row').forEach(tr => {
                subTotal += parseFloat(tr.querySelector('.row-amount').textContent) || 0;
                disc += parseFloat(tr.querySelector('.row-discount').value) || 0;
                tax += parseFloat(tr.querySelector('.row-tax').value) || 0;
            });
            const adj = parseFloat(document.getElementById('modal-adjustment').value) || 0;
            const grand = (subTotal - disc) + tax + adj;

            document.getElementById('modal-sub-total').textContent = '£ ' + subTotal.toFixed(2);
            document.getElementById('modal-discount').textContent = '£ ' + disc.toFixed(2);
            document.getElementById('modal-tax').textContent = '£ ' + tax.toFixed(2);
            document.getElementById('modal-grand-total').textContent = '£ ' + grand.toFixed(2);

            if (currentPlotId && plotDataMap[currentPlotId]) {
                Object.assign(plotDataMap[currentPlotId], {
                    subTotal, discountTotal: disc,
                    taxTotal: tax, adjustment: adj, grandTotal: grand
                });
            }
        }

        // Flush ALL row DOM data → plotDataMap (called on every cell change + add/remove row)
        function syncRows() {
            if (!currentPlotId || !plotDataMap[currentPlotId]) return;
            const flatRecords = [];
            document.querySelectorAll('#modal-tbody .modal-row').forEach(tr => {
                flatRecords.push({
                    id: tr.dataset.id,
                    productName: tr.querySelector('.row-product').value,
                    qty: parseFloat(tr.querySelector('.row-qty').value) || 0,
                    listPrice: parseFloat(tr.querySelector('.row-price').value) || 0,
                    amount: parseFloat(tr.querySelector('.row-amount').textContent) || 0,
                    discount: parseFloat(tr.querySelector('.row-discount').value) || 0,
                    tax: parseFloat(tr.querySelector('.row-tax').value) || 0,
                    total: parseFloat(tr.querySelector('.row-total').textContent) || 0,
                    // We need to keep the location mapping
                    locationName: tr.dataset.location || "Default"
                });
            });

            // Regroup flatRecords back into locations
            const groups = {};
            flatRecords.forEach(r => {
                if (!groups[r.locationName]) groups[r.locationName] = [];
                groups[r.locationName].push(r);
            });

            plotDataMap[currentPlotId].locations = Object.keys(groups).map(locName => ({
                name: locName,
                records: groups[locName]
            }));

            plotDataMap[currentPlotId].adjustment = parseFloat(document.getElementById('modal-adjustment').value) || 0;
            recalcTotals();
        }

