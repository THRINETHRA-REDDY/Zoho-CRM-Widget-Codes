        function processQuoteData(record) {
            console.log("Processing Record:", record);

            // ===== BASIC FIELDS =====
            var contactName = record.Contact_Name ? record.Contact_Name.name : "";
            var ownerName = record.Owner ? record.Owner.name : "";
            var SiteName = record.Site_Name || "";

            document.getElementById("subject").value = record.Subject || "";
            document.getElementById("quote_number").value = record.Quote_Number || "";
            document.getElementById("sales_person").value = ownerName;
            document.getElementById("customer").value = contactName;
            document.getElementById("due_date").value = record.Valid_Till || "";
            document.getElementById("project_manager").value = ownerName;
            document.getElementById("site").value = SiteName;

            // ===== PRODUCTS =====
            var products = record.Quoted_Items || [];
            console.log("Products:", products);

            // ===== AUTO FILL DATA (NO UI SWITCH) =====
            var groupedData = {};
            products.forEach(function (item) {
                var productName = item.Product_Name ? item.Product_Name.name : "";
                var qty = item.Quantity || 0;
                var price = item.Product_Name ? (item.Product_Name.Unit_Price || 0) : 0;
                var total = item.Total || (qty * price);
                var location = item.Location || "No Plot";
                var block = item.Block || "No Block";

                if (!groupedData[block]) groupedData[block] = {};
                if (!groupedData[block][location]) groupedData[block][location] = [];

                groupedData[block][location].push({ productName, qty, price, total });
            });

            // Clean existing sections
            document.getElementById("sections-container").innerHTML = '<div class="yellow-alert" id="no-sections-alert" style="margin-bottom:24px;"> <i class="fa-solid fa-triangle-exclamation"></i> No sections have been added yet. Create one above. </div>';
            for (var key in plotDataMap) delete plotDataMap[key];

            // ===== CREATE SECTIONS + DATA =====
            Object.keys(groupedData).forEach(function (block) {
                document.getElementById("new-section-name").value = block;
                addSection();

                var plotId = Object.keys(plotDataMap)[Object.keys(plotDataMap).length - 1];

                Object.keys(groupedData[block]).forEach(function (location) {
                    const locObj = {
                        name: location,
                        records: []
                    };

                    // Add Products
                    groupedData[block][location].forEach(function (prod) {
                        itemCount++;
                        var itemId = `item-${itemCount}`;
                        locObj.records.push({
                            id: itemId,
                            productName: prod.productName,
                            qty: prod.qty,
                            listPrice: prod.price,
                            amount: prod.qty * prod.price,
                            discount: 0,
                            tax: 0,
                            total: prod.total,
                            locationName: location // Metadata for modal/sync
                        });
                    });

                    plotDataMap[plotId].locations.push(locObj);
                });

                // ===== TOTAL CALCULATION =====
                var subTotal = 0, taxTotal = 0, grandTotal = 0;
                plotDataMap[plotId].locations.forEach(loc => {
                    loc.records.forEach(function (r) {
                        subTotal += r.amount;
                        taxTotal += r.tax || 0;
                        grandTotal += r.total;
                    });
                });

                plotDataMap[plotId].subTotal = subTotal;
                plotDataMap[plotId].taxTotal = taxTotal;
                plotDataMap[plotId].grandTotal = grandTotal;

                renderSectionProducts(plotId);
            });
        }


        // Initialization and Simulation Trigger
        var simulationTriggered = false;

        function startSimulation() {
            if (simulationTriggered) return;
            simulationTriggered = true;
            console.log("Triggering simulation with mock data...");
            processQuoteData(mockData.details.output);
        }

        if (typeof ZOHO !== 'undefined') {
            ZOHO.embeddedApp.on("PageLoad", function (data) {
                var recordId = data.EntityId ? data.EntityId[0] : null;
                console.log("Record ID from PageLoad:", recordId);
                currentrecordid=recordId;
                if (!recordId) {
                    startSimulation();
                } else {
                    ZOHO.CRM.FUNCTIONS.execute("Fetch_Qoute", { "quote_id": recordId })
                        .then(function (res) {
                            var record = JSON.parse(res.details.output);
                            processQuoteData(record);
                            simulationTriggered = true; // Mark as done so fallback doesn't run
                        }).catch(function (error) {
                            console.error("Function Error:", error);
                            startSimulation();
                        });
                }
            });
            ZOHO.embeddedApp.init();

            // Fallback: If ZOHO init doesn't trigger PageLoad within 1.5s, run simulation
            setTimeout(startSimulation, 1500);
        } else {
            // Standalone mode: trigger immediately on DOM ready
            if (document.readyState === 'complete') {
                startSimulation();
            } else {
                window.addEventListener('load', startSimulation);
            }
        }
    </script>
</body>

