        function syncLocationOrder(plotId) {
            const container = document.getElementById(`records-${plotId}`);
            const newLocations = [];
            container.querySelectorAll('.location-group').forEach(groupEl => {
                const locName = groupEl.dataset.locationName;
                const loc = plotDataMap[plotId].locations.find(l => l.name === locName);
                if (loc) newLocations.push(loc);
            });
            plotDataMap[plotId].locations = newLocations;
        }

        document.addEventListener('DOMContentLoaded', initSectionSortable);

        // ─── Navigation ────────────────────────────────────────────────────────────
        function toggleSections() {
            document.getElementById("section-1-wrapper").classList.toggle("d-none");
            document.getElementById("section-2-wrapper").classList.toggle("d-none");
        }
        const plotDataMap = {};
        let plotCount = 0;
        let itemCount = 0;
        let currentPlotId = null;

        function makeTitleEditable(element, plotId) {
            if (element.querySelector('input')) return;

            const currentTitle = element.innerText;
            element.innerHTML = `<input type="text" class="form-control" value="${currentTitle}" style="display:inline-block; width:auto; height:24px; padding:2px 4px; font-size:13px;">`;
            const input = element.querySelector('input');
            input.focus();
            input.select();

            const saveTitle = () => {
                const newTitle = input.value.trim() || currentTitle;
                plotDataMap[plotId].title = newTitle;
                element.innerText = newTitle;
            };

            input.onblur = saveTitle;
            input.onkeydown = (e) => {
                if (e.key === 'Enter') {
                    input.blur();
                } else if (e.key === 'Escape') {
                    element.innerText = currentTitle;
                }
            };
        }

        function getSectionTemplate(plotId, label) {
            return `
        <div class="plot-box" id="${plotId}">
            <div class="plot-header">
                <i class="fa-solid fa-grip-vertical" style="color:#ccc;margin-right:8px;font-size:10px;"></i>
                <span class="plot-title" ondblclick="makeTitleEditable(this, '${plotId}')" style="cursor:pointer;">${label}</span>
                <select class="form-control" style="background-color:#fff; width:fit-content; height:28px; padding:2px 8px; font-size:12px; margin-left:auto;" onchange="handleSectionAction('${plotId}', this.value)">
                    <option value="">Actions</option>
                    <option value="duplicate">Duplicate</option>
                    <option value="delete">Delete</option>
                </select>
            </div>
            <div class="plot-body">

                <div id="records-${plotId}"></div>

                <div class="yellow-alert" id="alert-${plotId}">
                    <i class="fa-solid fa-triangle-exclamation"></i>
                    No items have been added to this section.
                </div>

                <div class="plot-footer" id="footer-${plotId}" style="display:none;">
                    <div style="display:flex;gap:32px;color:#333;margin-left:auto;margin-right:12px;">
                        <span>Sub Total: <span class="plot-subtotal" style="font-weight:400;margin-left:6px;color:#555;">£0.00</span></span>
                        <span>Tax: <span class="plot-tax" style="font-weight:400;margin-left:6px;color:#555;">£0.00</span></span>
                        <span>Total: <span class="plot-grandtotal" style="font-weight:400;margin-left:6px;color:#555;">£0.00</span></span>
                    </div>
                </div>
            </div>
        </div>
        `;
